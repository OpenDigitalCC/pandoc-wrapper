% ============================================================================
% ODCC CUSTOMIZATIONS
% ============================================================================

\usepackage[most]{tcolorbox}
% Note: wrapfig, marginnote, ifoddpage, needspace now loaded in template-required packages section
\usepackage{hyperref}

% Margin notes setup
\renewcommand{\marginpar}{\marginnote}
\setlength{\marginparwidth}{4cm}
\let\oldmarginpar\marginpar

% Quote box command
\newcommand{\quoteBox}[2]{%
  \begin{tcolorbox}[%
    colframe=odcc-teal!90,
    colback=odcc-teal!10,
    boxrule=0.5pt,
    arc=2mm,
    auto outer arc,
    left=0.5mm, right=0.5mm,
  ]
    {\LARGE\textquotedblleft}{\large\itshape #1}{\LARGE\textquotedblright}
    \if\relax\detokenize{#2}\relax
    \else
    \\[1ex]\raggedleft\bfseries #2%
    \fi
  \end{tcolorbox}%
}

% Margin quote command
\newcommand{\marginquote}[2]{%
  \marginpar{\quoteBox{#1}{#2}}%
}

% End document handling - ensure page count for print binding with backpage
$if(printready)$
$if(backpage)$
% Ensure final page count (including backpage) is divisible by 4
\makeatletter
\AtEndDocument{%
  \clearpage
  % Current page will have backpage content
  % We want (current page) mod 4 = 0, so backpage is on page 4n
  \@tempcnta=\value{page}%
  \divide\@tempcnta by 4%
  \multiply\@tempcnta by 4%
  \@tempcntb=\value{page}%
  \advance\@tempcntb by -\@tempcnta%
  % \@tempcntb now contains (page mod 4)
  \ifcase\@tempcntb
    % 0: page is 4n, perfect - backpage will be on 4n (even, divisible by 4)
  \or
    % 1: page is 4n+1, add 3 blanks to reach 4(n+1) for backpage
    \thispagestyle{empty}\null\clearpage\thispagestyle{empty}\null\clearpage\thispagestyle{empty}\null\clearpage
  \or
    % 2: page is 4n+2, add 2 blanks to reach 4(n+1) for backpage
    \thispagestyle{empty}\null\clearpage\thispagestyle{empty}\null\clearpage
  \or
    % 3: page is 4n+3, add 1 blank to reach 4(n+1) for backpage
    \thispagestyle{empty}\null\clearpage
  \fi
}
\makeatother
$endif$
$endif$

