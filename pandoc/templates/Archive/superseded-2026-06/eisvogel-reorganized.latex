% Configure endnotes heading name
$if(endnotes-heading)$
\renewcommand{\notesname}{$endnotes-heading$}
$else$
% Use default from endnotes package (Notes)
$endif$

% Convert footnotes to endnotes
$if(footnotes-as-endnotes)$
\let\footnote=\endnote
$endif$

% Reduce spacing between endnotes (preserve default formatting but adjust spacing)
\makeatletter
\renewcommand\enoteformat{%
  \raggedright%
  \leftskip=1.8em%
  \parindent=-1.8em%
  \leavevmode\llap{\makeenmark}%
}
% Reduce vertical space between endnotes
\def\enoteheight{0.2\baselineskip}
% Make endnotes more compact
\renewcommand\enotesize{\small}
\makeatother

% Custom endnotes heading with TOC entry and margin adjustment
$if(endnotes-custom-heading)$
\makeatletter
\renewcommand\enoteheading{%
  $if(endnotes-symmetric-margins)$
  \clearpage%
  $if(printready)$
  % Adjust for crop mark offset
  \newgeometry{left=3cm,right=3cm,top=3cm,bottom=4cm}%
  $else$
  \newgeometry{left=2cm,right=2cm,top=2cm,bottom=3cm}%
  $endif$
  % Reset header/footer width to text width for symmetric margins
  \KOMAoptions{headwidth=text,footwidth=text}%
  $else$
  % Without symmetric margins, just add space
  \vspace{2em}%
  $endif$
  \section*{\notesname}%
  \markboth{\notesname}{\notesname}%
  \addcontentsline{toc}{chapter}{\notesname}%
  \mbox{}\par\vskip-\baselineskip%
}
\AtEndDocument{%
  \ifnum\value{endnote}>0%
    \theendnotes%
    $if(endnotes-symmetric-margins)$
    \restoregeometry%
    % Restore header/footer to extended width
    \KOMAoptions{headwidth=textwithmarginpar,footwidth=textwithmarginpar}%
    $endif$
  \fi%
  $if(printready)$
  $if(backpage)$
  % Backpage case handled separately below
  $else$
  % No backpage - add blank page if needed for even count
  \clearpage
  \ifodd\value{page}%
    \thispagestyle{empty}\mbox{}\clearpage
  \fi%
  $endif$
  $endif$
}
\makeatother
$endif$

