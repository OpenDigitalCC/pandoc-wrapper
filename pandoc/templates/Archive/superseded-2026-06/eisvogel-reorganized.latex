% Horizontal line above publisher info (matches titlepage rule)
\newcommand{\colorRule}[3][black]{\textcolor[HTML]{#1}{\rule{#2}{#3}}}
\noindent
\colorRule[$if(titlepage-rule-color)$$titlepage-rule-color$$else$435488$endif$]{\textwidth}{$if(titlepage-rule-height)$$titlepage-rule-height$$else$4$endif$pt}
\vspace{1em}

$if(backpage-publisher)$
{\small\textbf{$backpage-publisher$}}\\
$endif$
$if(backpage-address)$
{\small $backpage-address$}\\
$endif$
$if(backpage-website)$
{\small $backpage-website$}\\
$endif$
$if(backpage-isbn)$
\vspace{0.5em}
{\small ISBN: $backpage-isbn$}\\
$endif$
$if(backpage-copyright)$
{\small $backpage-copyright$}
$else$
$if(date)$
{\small \textcopyright\ $date$}

$if(author)$
$for(author)$
{\small $if(author.name)$$author.name$$else$$author$$endif$$if(author.affiliation)$, $author.affiliation$$endif$$if(author.email)$ (\href{mailto:$author.email$}{$author.email$})$endif$}

$endfor$
$endif$
$endif$
$endif$

\end{flushleft}
}
$endif$

\end{document}

