\dominitoc
$endif$

$if(cover-pdf)$
% Insert custom cover PDF as first page(s)
$if(printready)$
% With crop marks - manually add them since includepdf bypasses normal shipout
\includepdf[pages=-,pagecommand={\thispagestyle{empty}},
  picturecommand={%
    \begin{tikzpicture}[remember picture,overlay]
      \def\bleed{1cm}
      \def\marklen{5mm}
      \def\markgap{2mm}
      % Bottom-left corner
      \draw[line width=0.4pt] (\bleed-\marklen,\bleed) -- (\bleed-\markgap,\bleed);
      \draw[line width=0.4pt] (\bleed,\bleed-\marklen) -- (\bleed,\bleed-\markgap);
      % Bottom-right corner  
      \draw[line width=0.4pt] (\paperwidth-\bleed+\markgap,\bleed) -- (\paperwidth-\bleed+\marklen,\bleed);
      \draw[line width=0.4pt] (\paperwidth-\bleed,\bleed-\marklen) -- (\paperwidth-\bleed,\bleed-\markgap);
      % Top-left corner
      \draw[line width=0.4pt] (\bleed-\marklen,\paperheight-\bleed) -- (\bleed-\markgap,\paperheight-\bleed);
      \draw[line width=0.4pt] (\bleed,\paperheight-\bleed+\markgap) -- (\bleed,\paperheight-\bleed+\marklen);
      % Top-right corner
      \draw[line width=0.4pt] (\paperwidth-\bleed+\markgap,\paperheight-\bleed) -- (\paperwidth-\bleed+\marklen,\paperheight-\bleed);
      \draw[line width=0.4pt] (\paperwidth-\bleed,\paperheight-\bleed+\markgap) -- (\paperwidth-\bleed,\paperheight-\bleed+\marklen);
    \end{tikzpicture}%
  }]{$cover-pdf$}
$else$
\includepdf[pages=-,pagecommand={\thispagestyle{empty}}]{$cover-pdf$}
$endif$
$endif$

$if(titlepage)$
\begin{titlepage}
$if(titlepage-background)$
\newgeometry{top=2cm, right=4cm, bottom=3cm, left=4cm}
$else$
\newgeometry{left=6cm}
$endif$
$if(titlepage-color)$
\definecolor{titlepage-color}{HTML}{$titlepage-color$}
\newpagecolor{titlepage-color}\afterpage{\restorepagecolor}
$endif$
$if(titlepage-background)$
\tikz[remember picture,overlay] \node[inner sep=0pt] at (current page.center){\includegraphics[width=\paperwidth,height=\paperheight]{$titlepage-background$}};
$endif$
\newcommand{\colorRule}[3][black]{\textcolor[HTML]{#1}{\rule{#2}{#3}}}
\begin{flushleft}
\noindent
\\[-1em]
\color[HTML]{$if(titlepage-text-color)$$titlepage-text-color$$else$5F5F5F$endif$}
\makebox[0pt][l]{\colorRule[$if(titlepage-rule-color)$$titlepage-rule-color$$else$435488$endif$]{1.3\textwidth}{$if(titlepage-rule-height)$$titlepage-rule-height$$else$4$endif$pt}}
\par
\noindent

$if(titlepage-background)$
% The titlepage with a background image has other text spacing and text size
{
  \setstretch{2}
  \vfill
  \vskip -8em
  \noindent {\huge \textbf{\textsf{$title$}}}
  $if(subtitle)$
  \vskip 1em
  {\Large \textsf{$subtitle$}}
  $endif$
  \vfill
  \vskip 2em
  $for(author)$
  \noindent {\Large \textsf{$if(author.name)$$author.name$$else$$author$$endif$}}
  $if(author.affiliation)$
  \vskip 0.15em
  \noindent {\large \textsf{$author.affiliation$}}
  $endif$
  \vskip 0.8em
  $endfor$
  $if(date)$
  \vskip 0.4em
  \noindent {\Large \textsf{$date$}}
  $endif$
}
$else$
{
  \setstretch{1.4}
  \vfill
  \noindent {\huge \textbf{\textsf{$title$}}}
  $if(subtitle)$
  \vskip 1em
  {\Large \textsf{$subtitle$}}
  $endif$
  \vfill
  \vskip 2em
  $for(author)$
  \noindent {\Large \textsf{$if(author.name)$$author.name$$else$$author$$endif$}}
  $if(author.affiliation)$
  \vskip 0.15em
  \noindent {\large \textsf{$author.affiliation$}}
  $endif$
  \vskip 0.8em
  $endfor$
}
$endif$

$if(titlepage-logo)$
\vskip 1em
\noindent
\includegraphics[width=$if(logo-width)$$logo-width$$else$35mm$endif$]{$titlepage-logo$}
$endif$

$if(titlepage-background)$
$else$
\textsf{$date$}
$endif$
\end{flushleft}
\end{titlepage}
\restoregeometry
