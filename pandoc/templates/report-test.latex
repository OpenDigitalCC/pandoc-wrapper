% 
% Draw boxes

% Main blue box
\psframe*[linecolor=mblue, fillcolor=mblue, opacity=0.99, fillstyle=solid ](0,140)(210,0)


% add a line
\psline[linecolor=lgreen, fillcolor=lgreen ](15,232)(145,232)



%pscircle[linestyle=none,fillstyle=solid,fillcolor=](30,100){2}

% add the cover image
$if(coverimage)$
  \begin{tikzpicture}[remember picture,overlay,shift={(current page.center)},yshift=-4cm]
  \clip (0,0) circle (5.5cm) ;
  \node[anchor=center,yshift=0cm]{\includegraphics[width=11cm]{$coverimage$}};
  \end{tikzpicture}
$else$
  \pscircle[linecolor=lblue, fillcolor=mblue, opacity=1, fillstyle=solid ](110,110){5.5}
$endif$

% draw the circles
%\pscircle[linecolor=mblue, fillcolor=white, opacity=1, fillstyle=solid ](110,110){5.5}
%\pscircle[linecolor=lblue, fillcolor=mblue, opacity=1, fillstyle=solid ](110,110){5.5}
%\pscircle[fillcolor=lblue, linestyle=none, opacity=0.50, fillstyle=solid ](45,100){2.2}
%\pscircle[linecolor=lpink, opacity=0.50 ](180,150){2}
%\pscircle[linecolor=mpink, opacity=0.50 ](175,85){2}
%\pscircle[linecolor=white, opacity=0.50 ](50,125){1}

$if(clientlogo)$
  \pscircle[linecolor=lpink, fillcolor=white, fillstyle=solid, opacity=1 ](180,150){2}
  \begin{tikzpicture}[overlay,shift={(current page.center)},yshift=4pt,xshift=213pt]
  \clip (0,0) circle (4cm) ;
  \node[anchor=center,yshift=0cm]{\includegraphics[width=3cm]{$clientlogo$}};
  \end{tikzpicture}
$endif$

%\pscircle[fillcolor=lgreen, linestyle=none, opacity=0.50, fillstyle=solid ](170,125){1.2}

% 
% % Add text from variables
% % [baselineleft](LH,LV)

$if(classification)$
% classification box
	\psframe*[linecolor=lblue, fillcolor=lblue, opacity=1, fillstyle=solid ](140,280)(200,290)
	\rput[t](175,286.5){\color{white}\montserratsemi\large\parbox[c]{6cm}{$classification$}}
$endif$
	
$if(clientname)$
	\hyphenpenalty=10000
	\raggedright % don't try to align the right of the text
	\rput[bl](15,235){\color{lgreen}\mdseries\LARGE\parbox[c]{12cm}{$clientname$}}
$endif$

% Create a box for top left content so it all alligns

\rput[tl](15,225){\color{lblue}\normalfont\fontsize{30}{34}\parbox[c]{16cm}{
\raggedright % don't try to align the right of the text
\hyphenpenalty=10000

$if(title)$
	\color{lblue}\montserratbold{$title$\par}
  \vspace{10pt}
$endif$

$if(subtitle)$
	\color{black}\montserrat\LARGE{$subtitle$\par}
$endif$

\vspace*{1\baselineskip}

\color{black}\normalfont\mdseries\normalsize

$if(fao)$
FAO: $fao$\par
$endif$

$if(date)$
Date: $date$\par
$endif$

$if(author)$
By: $for(author)$$author$$sep$, $endfor$
$endif$

$if(docver)$
Version: $docver$\par
$endif$


}} % End of top left content box

$if(overview)$

\rput[tl](140,270){\normalfont\parbox[c]{6cm}{{
\raggedright
\color{lgreen}\mdseries\large
Document overview
\color{black}\mdseries\normalsize

\begin{itemize}
	$for(overview)$\item[\color{lgreen}\bullet]$overview$ $sep$ $endfor$
\end{itemize}		
}}}
$endif$

\statictext

\end{pspicture}

\restoregeometry

% 
% 
	
$endif$
% End of if-titlepage



$if(abstract)$
\begin{abstract}
$abstract$
\end{abstract}
$endif$

$for(include-before)$
$include-before$
$endfor$

% If table of contents

$if(toc)$
{
$if(colorlinks)$
\hypersetup{linkcolor=$if(toccolor)$$toccolor$$else$$endif$}
$endif$
\setcounter{tocdepth}{$toc-depth$}
\tableofcontents
\newpage
}
$endif$


$if(lot)$
\listoftables
$endif$
$if(lof)$
\listoffigures
$endif$


% set the document default font
\color{black}\mdseries\normalsize

% Insert the body from the Markdown


$body$

% add things at the end

$if(natbib)$
$if(bibliography)$
$if(biblio-title)$
$if(book-class)$
\renewcommand\bibname{$biblio-title$}
$else$
\renewcommand\refname{$biblio-title$}
$endif$
$endif$
\bibliography{$for(bibliography)$$bibliography$$sep$,$endfor$}

$endif$
$endif$
$if(biblatex)$
\printbibliography$if(biblio-title)$[title=$biblio-title$]$endif$
$endif$

$for(include-after)$
$include-after$
$endfor$


% - Back cover

\newcommand\backcover{
% don't show watermark on back page
$if(watermark)$
\NoBgThispage
$endif$

\thispagestyle{empty}
\newgeometry{left=0cm,bottom=0cm,top=0cm,right=0cm}
% \includepdf[pages=1]{pandoc-templates/graphics/back-cover.pdf}
\restoregeometry

}


\newcommand*\cleartoleftpage{%
   \clearpage
   \ifodd\value{page}\hbox{}\vspace*{\fill}\clearpage\fi
}


% only print back cover if we have a titlepage
$if(title)$
\cleartoleftpage
\backcover
$endif$


\end{document}

