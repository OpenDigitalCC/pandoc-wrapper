%% Add static text
\newcommand\statictext{
\rput[bl](15,15){\color{white}\normalfont\parbox[c]{4cm}{

\begin{tikzpicture}[overlay,xshift=2mm, yshift=-10pt]
\node[anchor=center,yshift=0cm]{\includegraphics[width=0.3cm]{pandoc-templates/graphics/email.pdf}};
\node[anchor=center,yshift=-0.47cm]{\includegraphics[width=0.2cm]{pandoc-templates/graphics/phone.pdf}};
\node[anchor=center,yshift=-0.94cm]{\includegraphics[width=0.3cm]{pandoc-templates/graphics/home.pdf}};
\end{tikzpicture}

%\normalsize\bfseries
%\hspace{6mm}hello@opusvl.com\par
%\hspace{6mm}01788 298 450\par
%\hspace{6mm}opusvl.com\par

%\vspace*{1\baselineskip}\small\mdseries
%Drury House\par
%Drury Lane\par
%Rugby CV21 3DE\par
%\vspace*{1\baselineskip}\footnotesize
%Opus Vision Limited t/a OpusVL\par
%Company No. 03905104\par
%VAT No. GB 747 8294 82\par
%}}


\rput[bl](110,15){\color{opusvllightblue}\montserrat\mdseries\normalsize\parbox[c]{8.5cm}{ 
Open source \montserratbold{business management software}.\par
\mdseries\montserrat
Customised to \montserratbold{fit the way you work}.
}}
\pscircle[linecolor=myell, opacity=0.50 ](170,-20){10}

} % end static text func


