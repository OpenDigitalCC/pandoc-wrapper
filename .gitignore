# Claude Code local (per-machine) settings
/.claude/settings.local.json

# Scratch / one-off diagnostics
/tmp/

# Pandoc / LaTeX build by-products
*-compiled.md
pandoc.log
pandoc.log.json
*.aux
*.toc
*.out
*.log
